    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var stagedItem = OrderStateService.GetStagedOrder();
            if (stagedItem != null && stagedItem.OrderItems != null && stagedItem.OrderItems.Any())
            {
                orderItems = stagedItem.OrderItems.ToList();
            }
            else
            {
                orderItems = CartService.GetCartItems();
            }

            CartService.OnChange += HandleCartChanged;
            StateHasChanged();
        }
    }

    private void HandleCartChanged()
    {
        orderItems = CartService.GetCartItems();
        InvokeAsync(StateHasChanged);
    }

    private void HandlePhoneInput(ChangeEventArgs e)
    {
        var input = e.Value?.ToString() ?? string.Empty;
        // This filters out any letters/symbols and keeps only numbers
        phoneNumberInput = new string(input.Where(char.IsDigit).ToArray());
    }

    private async Task PlaceOrder()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to place this order?");
        if (!confirmed) return;

        if (!orderItems.Any() ||
            string.IsNullOrWhiteSpace(customerName) ||
            string.IsNullOrWhiteSpace(phoneNumberInput) ||
            string.IsNullOrWhiteSpace(customerAddress))
        {
            return;
        }

        using var context = DbFactory.CreateDbContext();

        var orderItemsForDb = new List<OrderItem>();
        foreach (var item in orderItems)
        {
            var productFromDb = await context.Products.FindAsync(item.Product.ProductId);
            if (productFromDb != null)
            {
                orderItemsForDb.Add(new OrderItem
                {
                    Product = productFromDb,
                    Quantity = item.Quantity,
                    Price = item.Price,
                    Size = item.Size,
                    CustomName = item.CustomName,
                    CustomNumber = item.CustomNumber
                });
            }
        }

        // Commission Logic
        var commissionSetting = await context.CommissionSettings.FirstOrDefaultAsync();
        if (commissionSetting == null)
        {
            commissionSetting = new CommissionSetting { CurrentRate = 0.07m };
            context.CommissionSettings.Add(commissionSetting);
            await context.SaveChangesAsync();
        }

        decimal orderCommission = 0;
        string referralCode = ReferralService.GetReferralCode();
        if (string.IsNullOrEmpty(referralCode))
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity.IsAuthenticated && user.IsInRole("Influencer"))
            {
                var appUser = await UserManager.GetUserAsync(user);
                if (appUser != null && !string.IsNullOrEmpty(appUser.ReferralCode))
                {
                    referralCode = appUser.ReferralCode;
                }
            }
        }

        bool hasReferralCode = !string.IsNullOrEmpty(referralCode);
        if (hasReferralCode) orderCommission = Subtotal * commissionSetting.CurrentRate;

        // Create Order
        var order = new Order
        {
            CustomerName = customerName,
            CustomerPhone = customerPhone,
            CustomerAddress = customerAddress,
            OrderDate = DateTime.UtcNow,
            OrderItems = orderItemsForDb,
            TotalAmount = Subtotal,
            ReferralCode = referralCode,
            Status = "Pending",
            CommissionAmount = orderCommission,
            OptionalMessage = string.IsNullOrWhiteSpace(optionalMessage) ? "" : optionalMessage,
            IsVisibleToInfluencer = hasReferralCode,
            PaymentMethod = paymentMethod,
            PaymentStatus = "Pending",
            PaymentReference = $"ORD-{DateTime.Now.Ticks}-{new Random().Next(1000, 9999)}"
        };

        context.Orders.Add(order);
        await context.SaveChangesAsync();
        OrderStateService.NotifyOrderPlaced();

        Logger.LogInformation($"Order {order.Id} placed with reference {order.PaymentReference}. Method: {paymentMethod}");

        if (paymentMethod == "NotchPay")
        {
            // >>> ONLINE PAYMENT FLOW <<<

            var callbackUrl = NavigationManager.ToAbsoluteUri("/payment-callback").ToString();
            var email = "customer@maillotstore.store";

            Logger.LogInformation($"Initializing NotchPay for {order.PaymentReference} with callback {callbackUrl}");

            var initResponse = await NotchPayService.InitializePaymentAsync(order.TotalAmount, email, order.PaymentReference, callbackUrl);

            if (initResponse != null && !string.IsNullOrEmpty(initResponse.AuthorizationUrl))
            {
                if (!string.IsNullOrEmpty(initResponse.Reference) && initResponse.Reference != order.PaymentReference)
                {
                    Logger.LogInformation($"Updating Order Reference from {order.PaymentReference} to {initResponse.Reference}");
                    order.PaymentReference = initResponse.Reference;
                    await context.SaveChangesAsync();
                }

                // REMOVED THE CLEAR CART LOGIC FROM HERE.
                // The cart stays full until they actually pay!

                Logger.LogInformation($"Redirecting to NotchPay: {initResponse.AuthorizationUrl}");
                NavigationManager.NavigateTo(initResponse.AuthorizationUrl);
            }
            else
            {
                Logger.LogError("NotchPay initialization failed.");
                await JSRuntime.InvokeVoidAsync("alert", "Could not initialize payment. Please try again or use WhatsApp.");
            }
        }
        else
        {
            // >>> WHATSAPP / CASH ON DELIVERY FLOW <<<

            // --- SPEED FIX: Run Background Task (Fire and Forget) ---
            _ = Task.Run(async () =>
            {
                try
                {
                    await WhatsAppService.SendOrderNotificationsAsync(order);
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Failed to send background WhatsApp notification");
                }
            });
            // --------------------------------------------------------

            var messageBuilder = new StringBuilder();
            messageBuilder.AppendLine("Hello Maillot Store,");
            messageBuilder.AppendLine();
            messageBuilder.AppendLine($"An order has been placed (Order ID: {order.Id}):");
            messageBuilder.AppendLine($"  Name: {customerName}");
            messageBuilder.AppendLine($"  Phone: {customerPhone}");
            messageBuilder.AppendLine($"  Address: {customerAddress}");
            messageBuilder.AppendLine();
            messageBuilder.AppendLine($"  Total: FCFA {Subtotal:N0} XAF");
            messageBuilder.AppendLine("I am waiting for confirmation.");

            var adminSetting = await context.AdminSettings.FirstOrDefaultAsync(s => s.Key == "AdminWhatsAppNumber");
            var adminPhoneNumber = adminSetting?.Value?.Replace("+", "").Replace(" ", "") ?? "237671007313";
            if (!adminPhoneNumber.StartsWith("237")) adminPhoneNumber = "237" + adminPhoneNumber;

            string whatsappUrl = $"https://wa.me/{adminPhoneNumber}?text={Uri.EscapeDataString(messageBuilder.ToString())}";

            await JSRuntime.InvokeVoidAsync("open", whatsappUrl, "_blank");

            // Clear Cart here because Cash on Delivery means they finalized the checkout process.
            CartService.ClearCart();
            OrderStateService.ClearStagedOrder();
            NavigationManager.NavigateTo("/shop");
        }
    }

    private void RemoveFromCart(OrderItem item)
    {
        CartService.RemoveFromCart(item);
    }

    private void UpdateQuantity(OrderItem item, int quantity)
    {
        CartService.UpdateQuantity(item, quantity);
    }

    private void UpdateSize(OrderItem item, ChangeEventArgs e)
    {
        var newSize = e.Value?.ToString();
        if (!string.IsNullOrEmpty(newSize))
        {
            CartService.UpdateSize(item, newSize);
        }
    }

    public void Dispose()
    {
        CartService.OnChange -= HandleCartChanged;
    }
}